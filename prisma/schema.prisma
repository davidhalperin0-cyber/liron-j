generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  locale        String    @default("he")
  currency      String    @default("ILS")
  loyaltyPoints Int       @default(0)
  vipTier       VipTier   @default(NONE)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  wishlist      WishlistItem[]
  recentlyViewed RecentlyViewed[]
  reviews       Review[]
  addresses     Address[]
  cartItems     CartItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  CUSTOMER
  ADMIN
  EDITOR
}

enum VipTier {
  NONE
  SILVER
  GOLD
  PLATINUM
}

// ─── Products ───────────────────────────────────────

model Product {
  id              String        @id @default(cuid())
  slug            String        @unique
  nameEn          String
  nameHe          String
  descriptionEn   String?       @db.Text
  descriptionHe   String?       @db.Text
  storyEn         String?       @db.Text
  storyHe         String?       @db.Text
  price           Decimal       @db.Decimal(10, 2)
  compareAtPrice  Decimal?      @db.Decimal(10, 2)
  currency        String        @default("ILS")
  sku             String?       @unique
  material        String?
  color           String?
  gemstone        String?
  weight          String?
  dimensions      String?
  status          ProductStatus @default(DRAFT)
  isFeatured      Boolean       @default(false)
  isNewArrival    Boolean       @default(false)
  isLimited       Boolean       @default(false)
  trendingScore   Float         @default(0)
  popularityScore Float         @default(0)
  manualPriority  Int           @default(0)
  viewCount       Int           @default(0)
  purchaseCount   Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  variants           ProductVariant[]
  images             ProductImage[]
  tags               ProductTag[]
  collections        ProductCollection[]
  campaigns          ProductCampaign[]
  recommendationsFrom Recommendation[] @relation("FromProduct")
  recommendationsTo   Recommendation[] @relation("ToProduct")
  reviews            Review[]
  wishlistItems      WishlistItem[]
  recentlyViewed     RecentlyViewed[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  seoMetadata        SeoMetadata?

  @@index([categoryId])
  @@index([status])
  @@index([trendingScore])
  @@index([popularityScore])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  name        String
  sku         String? @unique
  color       String?
  size        String?
  material    String?
  chainLength String?
  price       Decimal? @db.Decimal(10, 2)
  stock       Int     @default(0)
  position    Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String    @id @default(cuid())
  productId String
  variantId String?
  url       String
  alt       String?
  position  Int       @default(0)
  type      ImageType @default(PHOTO)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("product_images")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ImageType {
  PHOTO
  MODEL_3D
  VIDEO
  LIFESTYLE
}

// ─── Categories & Tags ──────────────────────────────

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  nameEn      String
  nameHe      String
  descriptionEn String?  @db.Text
  descriptionHe String?  @db.Text
  image       String?
  parentId    String?
  position    Int        @default(0)
  isActive    Boolean    @default(true)

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ─── Collections ────────────────────────────────────

model Collection {
  id            String          @id @default(cuid())
  slug          String          @unique
  nameEn        String
  nameHe        String
  descriptionEn String?         @db.Text
  descriptionHe String?         @db.Text
  heroImage     String?
  type          CollectionType  @default(MANUAL)
  autoRules     Json?
  position      Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  products    ProductCollection[]
  seoMetadata SeoMetadata?

  @@map("collections")
}

model ProductCollection {
  productId    String
  collectionId String
  position     Int @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

enum CollectionType {
  MANUAL
  AUTO
}

// ─── Campaigns ──────────────────────────────────────

model Campaign {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameEn        String
  nameHe        String
  descriptionEn String?   @db.Text
  descriptionHe String?   @db.Text
  heroImage     String?
  bannerImage   String?
  startDate     DateTime?
  endDate       DateTime?
  discountType  DiscountType?
  discountValue Decimal?  @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products ProductCampaign[]

  @@map("campaigns")
}

model ProductCampaign {
  productId  String
  campaignId String
  position   Int @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([productId, campaignId])
  @@map("product_campaigns")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Recommendations ────────────────────────────────

model Recommendation {
  id                   String             @id @default(cuid())
  productId            String
  recommendedProductId String
  type                 RecommendationType
  position             Int                @default(0)
  isManual             Boolean            @default(false)

  product            Product @relation("FromProduct", fields: [productId], references: [id], onDelete: Cascade)
  recommendedProduct Product @relation("ToProduct", fields: [recommendedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, recommendedProductId, type])
  @@index([productId, type])
  @@map("recommendations")
}

enum RecommendationType {
  SIMILAR
  MATCHING
  COMPLETE_LOOK
  FREQUENTLY_BOUGHT
  STYLIST_PICK
  BUNDLE
}

// ─── Reviews ────────────────────────────────────────

model Review {
  id         String  @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  body       String? @db.Text
  isApproved Boolean @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("reviews")
}

// ─── Wishlist & Recently Viewed ─────────────────────

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  productId String
  viewedAt  DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("recently_viewed")
}

// ─── Cart ───────────────────────────────────────────

model CartItem {
  id        String @id @default(cuid())
  userId    String?
  sessionId String?
  productId String
  variantId String?
  quantity  Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([sessionId])
  @@map("cart_items")
}

// ─── Orders ─────────────────────────────────────────

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  userId          String?
  email           String
  status          OrderStatus  @default(PENDING)
  subtotal        Decimal      @db.Decimal(10, 2)
  shippingCost    Decimal      @default(0) @db.Decimal(10, 2)
  discount        Decimal      @default(0) @db.Decimal(10, 2)
  total           Decimal      @db.Decimal(10, 2)
  currency        String       @default("ILS")
  paymentMethod   String?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?
  notes           String?      @db.Text
  giftWrap        Boolean      @default(false)
  giftMessage     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User?        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  shippingAddress OrderAddress? @relation("ShippingAddress")
  billingAddress  OrderAddress? @relation("BillingAddress")
  statusHistory   OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderAddress {
  id        String @id @default(cuid())
  orderId   String
  type      AddressType
  name      String
  street    String
  city      String
  state     String?
  country   String
  zip       String
  phone     String?

  orderShipping Order? @relation("ShippingAddress")
  orderBilling  Order? @relation("BillingAddress")

  @@unique([orderId, type])
  @@map("order_addresses")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AddressType {
  SHIPPING
  BILLING
}

// ─── Addresses ──────────────────────────────────────

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String?
  name      String
  street    String
  city      String
  state     String?
  country   String
  zip       String
  phone     String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ─── Homepage ───────────────────────────────────────

model HomepageSection {
  id       String              @id @default(cuid())
  type     HomepageSectionType
  titleEn  String?
  titleHe  String?
  data     Json?
  position Int                 @default(0)
  isActive Boolean             @default(true)

  @@map("homepage_sections")
}

enum HomepageSectionType {
  HERO
  NEW_DROP
  TRENDING
  EDITORIAL
  CATEGORIES
  COMPLETE_LOOK
  FEATURED_COLLECTION
  PERSONALIZED
  CAMPAIGN_BANNER
  INSTAGRAM
  BRAND_STORY
  VIP
}

// ─── SEO ────────────────────────────────────────────

model SeoMetadata {
  id           String  @id @default(cuid())
  entityType   String
  productId    String? @unique
  collectionId String? @unique
  titleEn      String?
  titleHe      String?
  descriptionEn String?
  descriptionHe String?
  ogImage      String?

  product    Product?    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@map("seo_metadata")
}
